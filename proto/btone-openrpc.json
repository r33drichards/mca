  } ],
  "methods" : [ {
    "name" : "debug.echo",
    "summary" : "Echo whatever params were sent. Useful for transport tests.",
    "params" : [ {
      "name" : "params",
      "required" : false,
      "schema" : {
        "$ref" : "#/components/schemas/AnyObject"
      }
    } ],
    "result" : {
      "name" : "DebugEchoResult",
      "schema" : {
        "$ref" : "#/components/schemas/AnyObject"
      }
    },
    "paramStructure" : "by-name"
  }, {
