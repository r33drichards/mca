{
  "network": {
    "allowedDomains": [
      "api.anthropic.com",
      "claude.ai",
      "console.anthropic.com",
      "auth.anthropic.com",
      "statsig.anthropic.com",
      "github.com",
      "*.github.com",
      "*.githubusercontent.com",
      "raw.githubusercontent.com",
      "objects.githubusercontent.com",
      "codeload.github.com",
      "cdn.modrinth.com",
      "api.modrinth.com",
      "meteorclient.com",
      "registry.npmjs.org",
      "127.0.0.1",
      "localhost"
    ],
    "deniedDomains": [
      "169.254.169.254",
      "169.254.170.2",
      "metadata.google.internal"
    ],
    "allowUnixSockets": [
      "/run/twitch-streamd/sock"
    ],
    "allowLocalBinding": false
  },
  "filesystem": {
    "denyRead": [
      "/etc/btone-stream/env",
      "/etc/btone-bot.env",
      "/etc/shadow",
      "/etc/gshadow",
      "/etc/sudoers",
      "/etc/sudoers.d",
      "/etc/ssh",
      "/home/ubuntu",
      "/home/btone",
      "/home/streamd",
      "/var/lib/twitch-streamd",
      "/var/lib/btone/.minecraft/saves",
      "/root",
      "/proc"
    ],
    "allowRead": [
      "/proc/self",
      "/proc/cpuinfo",
      "/proc/meminfo",
      "/proc/stat",
      "/proc/version",
      "/proc/uptime",
      "/proc/loadavg",
      "/proc/sys/kernel/random/uuid",
      "/proc/sys/kernel/osrelease",
      "/proc/sys/kernel/ostype"
    ],
    "allowWrite": [
      "/var/lib/btone/source",
      "/home/claudeop",
      "/tmp"
    ],
    "denyWrite": []
  },
  "ignoreViolations": {
    "*": ["/usr/bin", "/usr/lib", "/usr/share", "/usr/local", "/lib", "/lib64", "/bin", "/sbin"]
  },
  "enableWeakerNestedSandbox": false,
  "enableWeakerNetworkIsolation": true
}
